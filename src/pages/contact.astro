---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import IconLeaf from "../components/IconLeaf.astro";
import { site } from "../data/site.ts";

const mapQuery = encodeURIComponent(`${site.contact.address1}, ${site.contact.city}, ${site.contact.region} ${site.contact.postal}`);
---

<Layout
  title="Contact Focus Psychiatry"
  description="Call 281-968-7568 or send a message to book an appointment at Focus Psychiatry in Alvin, TX. Accepting new patients ages 14 and up."
>
  <PageHero
    eyebrow="Contact"
    title="Get in touch"
    subtitle="Call, message, or stop by. We'll respond within one business day."
  />

  <section class="py-16 md:py-20">
    <div class="container-prose grid lg:grid-cols-5 gap-10">
      <div class="lg:col-span-3 bg-white rounded-2xl p-8 border border-sage-100 shadow-sm">
        <h2 class="text-2xl text-sage-900">Send us a message</h2>
        <p class="mt-2 text-sage-700">For non-urgent inquiries. We typically respond within one business day.</p>

        <form name="contact" method="POST" data-netlify="true" action="/thank-you/" class="mt-8 grid gap-5">
          <input type="hidden" name="form-name" value="contact" />
          <div class="grid sm:grid-cols-2 gap-5">
            <label class="block">
              <span class="text-sm font-medium text-sage-800">First name *</span>
              <input required name="first_name" type="text" autocomplete="given-name" class="mt-1 block w-full rounded-md border border-sage-200 px-3 py-2 focus:border-sage-500 focus:ring-2 focus:ring-sage-200 outline-none" />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-sage-800">Last name *</span>
              <input required name="last_name" type="text" autocomplete="family-name" class="mt-1 block w-full rounded-md border border-sage-200 px-3 py-2 focus:border-sage-500 focus:ring-2 focus:ring-sage-200 outline-none" />
            </label>
          </div>
          <label class="block">
            <span class="text-sm font-medium text-sage-800">Email *</span>
            <input required name="email" type="email" autocomplete="email" class="mt-1 block w-full rounded-md border border-sage-200 px-3 py-2 focus:border-sage-500 focus:ring-2 focus:ring-sage-200 outline-none" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-sage-800">Phone</span>
            <input name="phone" type="tel" autocomplete="tel" class="mt-1 block w-full rounded-md border border-sage-200 px-3 py-2 focus:border-sage-500 focus:ring-2 focus:ring-sage-200 outline-none" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-sage-800">Reason for contact</span>
            <select name="reason" class="mt-1 block w-full rounded-md border border-sage-200 px-3 py-2 focus:border-sage-500 focus:ring-2 focus:ring-sage-200 outline-none bg-white">
              <option value="">Select one</option>
              <option>New patient appointment</option>
              <option>Existing patient question</option>
              <option>Insurance verification</option>
              <option>Suboxone / addiction treatment</option>
              <option>Telepsychiatry</option>
              <option>Other</option>
            </select>
          </label>
          <label class="block">
            <span class="text-sm font-medium text-sage-800">Message *</span>
            <textarea required name="message" rows="5" class="mt-1 block w-full rounded-md border border-sage-200 px-3 py-2 focus:border-sage-500 focus:ring-2 focus:ring-sage-200 outline-none"></textarea>
          </label>
          <p class="text-xs text-sage-600">Please do not share protected health information in this form. For urgent medical or mental health crises, call 988 or go to your nearest emergency room.</p>
          <button type="submit" class="btn-primary w-full sm:w-auto justify-self-start">Send Message</button>
        </form>
      </div>

      <aside class="lg:col-span-2 space-y-6">
        <div class="bg-sage-50 rounded-2xl p-7 border border-sage-100">
          <h2 class="text-xl text-sage-900">Visit</h2>
          <address class="not-italic mt-4 text-sage-800 leading-relaxed">
            {site.contact.address1}<br />
            {site.contact.city}, {site.contact.region} {site.contact.postal}
          </address>

          <div class="mt-6 space-y-4 text-sm">
            <div class="flex items-start gap-3">
              <IconLeaf name="clock" class="w-4 h-4 mt-0.5 text-sage-600 shrink-0" />
              <div>
                <p class="text-sage-600">Hours</p>
                <p class="text-sage-900 font-medium">Mon–Fri · 8:30 AM – 5:00 PM</p>
                <p class="text-sage-700">Closed Saturday & Sunday</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <IconLeaf name="pulse" class="w-4 h-4 mt-0.5 text-sage-600 shrink-0" />
              <div>
                <p class="text-sage-600">Phone</p>
                <p><a href={`tel:${site.contact.phoneRaw}`} class="text-sage-900 font-medium hover:underline">{site.contact.phone}</a></p>
                <p class="text-sage-700 text-xs">Fax {site.contact.fax}</p>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden border border-sage-100">
          <iframe
            title={`Map to ${site.name}`}
            src={`https://www.google.com/maps?q=${mapQuery}&output=embed`}
            width="100%"
            height="320"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>

        <div class="rounded-2xl p-6 border border-amber-200 bg-amber-50">
          <h3 class="text-sm font-semibold text-amber-900 uppercase tracking-wide">In a crisis?</h3>
          <p class="mt-2 text-sm text-amber-900">If you are having a mental health crisis, call <a href="tel:988" class="underline font-semibold">988</a> (Suicide & Crisis Lifeline) or go to your nearest emergency room.</p>
        </div>
      </aside>
    </div>
  </section>
</Layout>
