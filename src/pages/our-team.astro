---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";
import IconLeaf from "../components/IconLeaf.astro";
import ProviderPortrait from "../components/ProviderPortrait.astro";
import { site, providers } from "../data/site.ts";
---

<Layout
  title="Our Team"
  description={`Meet the team at Focus Psychiatry in Alvin, TX: ${providers.map((p) => p.name).join(" and ")}. Treating ages ${site.agesServed} in-person and by telepsychiatry across Texas.`}
>
  <section class="bg-gradient-to-b from-sage-50 to-cream border-b border-sage-100">
    <div class="container-prose py-16 md:py-20 max-w-4xl">
      <p class="text-sage-600 font-medium uppercase tracking-wider text-xs">Our Team</p>
      <h1 class="mt-3 text-4xl md:text-5xl lg:text-6xl text-sage-900 leading-tight">
        Meet your care team
      </h1>
      <p class="mt-5 text-lg md:text-xl text-sage-700 max-w-2xl leading-relaxed">
        Focus Psychiatry is intentionally a small practice. Every patient is seen and known personally by one of our providers — that continuity is part of the treatment.
      </p>
      <nav class="mt-8 flex flex-wrap gap-3 text-sm" aria-label="Provider jump links">
        {providers.map((p) => (
          <a href={`#${p.id}`} class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-sage-200 text-sage-800 hover:border-sage-400">
            <span class="w-1.5 h-1.5 rounded-full bg-sage-500"></span>
            {p.shortName}
          </a>
        ))}
      </nav>
    </div>
  </section>

  {providers.map((provider, index) => (
    <section
      id={provider.id}
      class:list={["py-16 md:py-24 scroll-mt-24", index % 2 === 1 ? "bg-sage-50 border-y border-sage-100" : ""]}
    >
      <div class="container-prose grid lg:grid-cols-12 gap-10 items-start">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-24">
            <ProviderPortrait provider={provider} size="md" />
            <div class="mt-6 text-center lg:text-left">
              <p class="text-warm-gold text-xs uppercase tracking-wider font-medium">{provider.role}</p>
              <h2 class="mt-2 text-2xl md:text-3xl text-sage-900">{provider.name}</h2>
              <p class="mt-2 text-sage-700 text-sm">Practicing since {provider.practicingSince} · Speaks {provider.languages.join(", ")}</p>
              <div class="mt-5 flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
                <a href="/contact/" class="btn-primary text-sm">Schedule a visit</a>
              </div>
            </div>
          </div>
        </div>

        <article class="lg:col-span-8 space-y-6 text-sage-800 leading-relaxed">
          <p class="text-lg">{provider.bio}</p>
          <p>{provider.training}</p>

          <h3 class="text-xl pt-4 text-sage-900">Education & training</h3>
          <ul class="space-y-4 not-prose">
            {provider.education.map((e) => (
              <li class="border-l-2 border-sage-300 pl-4">
                <p class="font-medium text-sage-900">{e.school}</p>
                <p class="text-sm text-sage-700">
                  {e.degree} · {e.years}{e.note ? ` · ${e.note}` : ""}
                </p>
              </li>
            ))}
          </ul>

          <h3 class="text-xl pt-4 text-sage-900">Licensure & certifications</h3>
          <ul class="space-y-3 not-prose">
            {provider.licensure.map((l) => (
              <li class="flex items-start gap-3">
                <IconLeaf name="shield" class="w-5 h-5 mt-0.5 text-sage-600 shrink-0" />
                <div>
                  <p class="font-medium text-sage-900">{l.title}</p>
                  {(l.issuer || l.date || l.note) && (
                    <p class="text-sm text-sage-700">
                      {[l.issuer, l.date].filter(Boolean).join(" · ")}
                      {l.note && <span class="block mt-1">{l.note}</span>}
                    </p>
                  )}
                </div>
              </li>
            ))}
          </ul>

          {provider.memberships && provider.memberships.length > 0 && (
            <>
              <h3 class="text-xl pt-4 text-sage-900">Professional memberships</h3>
              <ul class="space-y-2 not-prose">
                {provider.memberships.map((m) => (
                  <li class="text-sage-800">· {m}</li>
                ))}
              </ul>
            </>
          )}
        </article>
      </div>
    </section>
  ))}

  <CTASection variant="cream" heading="Have a question before you book?" subheading="Reach out — we'll respond within one business day." />
</Layout>
