---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";
import IconLeaf from "../components/IconLeaf.astro";
import GoogleRatingBadge from "../components/GoogleRatingBadge.astro";
import ReviewCard from "../components/ReviewCard.astro";
import ProviderPortrait from "../components/ProviderPortrait.astro";
import { getCollection } from "astro:content";
import { site, providers } from "../data/site.ts";
import { featuredReviews, googleRating } from "../data/reviews.ts";

const conditions = (await getCollection("conditions"))
  .sort((a, b) => a.data.order - b.data.order);

const services = (await getCollection("services"))
  .sort((a, b) => a.data.order - b.data.order);

const physicianSchema = {
  "@context": "https://schema.org",
  "@type": "Physician",
  name: site.doctor.name,
  medicalSpecialty: "Psychiatric",
  worksFor: { "@type": "MedicalOrganization", name: site.name },
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["MedicalBusiness", "LocalBusiness"],
  name: site.name,
  image: new URL("/logo.webp", site.url).toString(),
  url: site.url,
  telephone: site.contact.phone,
  faxNumber: site.contact.fax,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: site.contact.address1,
    addressLocality: site.contact.city,
    addressRegion: site.contact.region,
    postalCode: site.contact.postal,
    addressCountry: site.contact.country,
  },
  geo: { "@type": "GeoCoordinates", ...site.contact.geo },
  openingHoursSpecification: site.contact.hours.map((h) => ({
    "@type": "OpeningHoursSpecification",
    dayOfWeek: h.day,
    opens: h.open,
    closes: h.close,
  })),
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: googleRating.average,
    reviewCount: googleRating.count,
    bestRating: 5,
    worstRating: 1,
  },
};
---

<Layout
  title={`Psychiatrist in Alvin, TX | ${site.name}`}
  description={site.description}
  schema={[physicianSchema, localBusinessSchema]}
>
  <section class="relative bg-gradient-to-b from-sage-50 to-cream">
    <div class="container-prose py-20 md:py-28 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <p class="inline-flex items-center gap-2 text-sage-700 bg-sage-100 px-3 py-1 rounded-full text-xs font-medium uppercase tracking-wider">
          <span class="w-2 h-2 rounded-full bg-sage-500"></span>
          Accepting New Patients
        </p>
        <h1 class="mt-5 text-4xl md:text-5xl lg:text-6xl text-sage-900 leading-tight">
          Steady, thoughtful psychiatric care in Alvin, Texas.
        </h1>
        <p class="mt-6 text-lg md:text-xl text-sage-700 max-w-xl leading-relaxed">
          {site.name} is the practice of {site.doctor.name}. We treat depression, anxiety, ADHD, bipolar disorder, OCD, sleep issues, and addiction — for adolescents (14+) and adults. In-person and telepsychiatry visits available.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href="/contact/" class="btn-primary">Book an Appointment</a>
          <a href={`tel:${site.contact.phoneRaw}`} class="btn-secondary">
            Call {site.contact.phone}
          </a>
        </div>
        <div class="mt-10">
          <GoogleRatingBadge />
        </div>
      </div>
      <div class="lg:col-span-5">
        <div class="relative">
          <div class="absolute -top-6 -left-6 w-32 h-32 rounded-full bg-sage-200/50 blur-2xl"></div>
          <div class="relative bg-white rounded-2xl shadow-xl p-8 border border-sage-100">
            <p class="text-sage-600 text-xs uppercase tracking-wider font-medium">Visit Us</p>
            <p class="mt-2 text-sage-900 font-medium text-lg">{site.contact.address1}</p>
            <p class="text-sage-700">{site.contact.city}, {site.contact.region} {site.contact.postal}</p>
            <div class="mt-6 pt-6 border-t border-sage-100 space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-sage-600">Phone</span>
                <a href={`tel:${site.contact.phoneRaw}`} class="text-sage-900 font-medium">{site.contact.phone}</a>
              </div>
              <div class="flex justify-between">
                <span class="text-sage-600">Hours</span>
                <span class="text-sage-900 font-medium">Mon–Fri 8:30–5:00</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sage-600">Telepsych</span>
                <span class="text-sage-900 font-medium">Available</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24">
    <div class="container-prose">
      <div class="max-w-2xl mb-12">
        <p class="text-sage-600 font-medium uppercase tracking-wider text-xs">Conditions Treated</p>
        <h2 class="mt-3 text-3xl md:text-4xl text-sage-900">
          Care for the conditions that affect how you live, work, and feel.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {conditions.map((c) => (
          <a
            href={`/conditions/${c.id}/`}
            class="group block bg-white rounded-xl p-6 border border-sage-100 hover:border-sage-300 hover:shadow-lg transition-all"
          >
            <div class="w-10 h-10 rounded-lg bg-sage-100 text-sage-700 flex items-center justify-center mb-4 group-hover:bg-sage-200 transition-colors">
              <IconLeaf name={c.data.icon ?? "leaf"} class="w-5 h-5" />
            </div>
            <h3 class="text-lg text-sage-900">{c.data.title}</h3>
            <p class="mt-2 text-sm text-sage-700 leading-relaxed">{c.data.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24 bg-sage-50">
    <div class="container-prose">
      <div class="max-w-2xl mb-12">
        <p class="text-sage-600 font-medium uppercase tracking-wider text-xs">Treatments & Services</p>
        <h2 class="mt-3 text-3xl md:text-4xl text-sage-900">
          Modern psychiatric care, including advanced options for treatment-resistant cases.
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((s) => (
          <a
            href={`/services/${s.id}/`}
            class="group block bg-white rounded-xl p-7 border border-sage-100 hover:border-sage-300 hover:shadow-lg transition-all"
          >
            <div class="w-10 h-10 rounded-lg bg-sage-700 text-white flex items-center justify-center mb-5">
              <IconLeaf name={s.data.icon ?? "leaf"} class="w-5 h-5" />
            </div>
            <h3 class="text-xl text-sage-900">{s.data.title}</h3>
            <p class="mt-3 text-sage-700 leading-relaxed">{s.data.excerpt}</p>
            <p class="mt-5 text-sm font-medium text-sage-700 group-hover:text-sage-900">Learn more &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24">
    <div class="container-prose">
      <div class="max-w-2xl mb-12">
        <p class="text-sage-600 font-medium uppercase tracking-wider text-xs">Meet your providers</p>
        <h2 class="mt-3 text-3xl md:text-4xl text-sage-900">
          Compassionate, individualized care from a small team you'll know personally.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-10 lg:gap-14">
        {providers.map((provider) => (
          <article class="flex flex-col">
            <div class="mb-6">
              <ProviderPortrait provider={provider} size="sm" class="lg:mx-0" />
            </div>
            <p class="text-warm-gold text-xs uppercase tracking-wider font-medium">{provider.role}</p>
            <h3 class="mt-2 text-2xl text-sage-900">{provider.name}</h3>
            <p class="mt-2 text-sm text-sage-700">
              Practicing since {provider.practicingSince} · Speaks {provider.languages.join(", ")}
            </p>
            <p class="mt-5 text-sage-800 leading-relaxed flex-1">{provider.bio}</p>
            <a href={`/our-team/#${provider.id}`} class="mt-6 text-sage-700 hover:text-sage-900 font-medium text-sm self-start">
              Read full profile &rarr;
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24 bg-sage-50 border-y border-sage-100">
    <div class="container-prose">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
        <div class="max-w-2xl">
          <p class="text-sage-600 font-medium uppercase tracking-wider text-xs">What patients say</p>
          <h2 class="mt-3 text-3xl md:text-4xl text-sage-900">
            {googleRating.average} stars across {googleRating.count} Google reviews
          </h2>
        </div>
        <GoogleRatingBadge variant="stacked" />
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {featuredReviews.map((r) => (
          <ReviewCard review={r} />
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/reviews/" class="btn-secondary">Read all reviews</a>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
