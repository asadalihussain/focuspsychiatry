---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<Layout
  title="Blog & Resources"
  description="Articles and resources from Focus Psychiatry on mental health, addiction recovery, and what to expect from psychiatric treatment."
>
  <PageHero
    eyebrow="Blog & Resources"
    title="From the practice"
    subtitle="Updates, education, and resources for patients and families."
  />

  <section class="py-16 md:py-20">
    <div class="container-prose">
      {posts.length === 0 ? (
        <div class="bg-sage-50 rounded-xl p-10 text-center border border-sage-100">
          <h2 class="text-2xl text-sage-900">New posts coming soon</h2>
          <p class="mt-3 text-sage-700">Check back for articles from the practice.</p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((p) => (
            <a href={`/blog/${p.id}/`} class="block bg-white rounded-xl p-6 border border-sage-100 hover:border-sage-300 hover:shadow-lg transition-all">
              <time class="text-xs text-sage-600 uppercase tracking-wider">
                {p.data.publishedAt.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </time>
              <h2 class="mt-2 text-xl text-sage-900">{p.data.title}</h2>
              <p class="mt-3 text-sm text-sage-700 leading-relaxed">{p.data.excerpt}</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <CTASection />
</Layout>
