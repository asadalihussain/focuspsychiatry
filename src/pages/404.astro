---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found" description="The page you're looking for can't be found.">
  <section class="py-24 md:py-32">
    <div class="container-prose text-center max-w-xl">
      <p class="text-sage-600 font-medium uppercase tracking-wider text-xs">404</p>
      <h1 class="mt-3 text-4xl md:text-5xl text-sage-900">Page not found</h1>
      <p class="mt-5 text-sage-700 text-lg">The page you're looking for has moved or doesn't exist anymore.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn-primary">Back to home</a>
        <a href="/contact/" class="btn-secondary">Contact us</a>
      </div>
    </div>
  </section>
</Layout>
