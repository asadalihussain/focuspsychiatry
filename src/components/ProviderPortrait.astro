---
import type { Provider } from "../data/site.ts";
interface Props {
  provider: Provider;
  size?: "sm" | "md" | "lg";
  class?: string;
}
const { provider, size = "md", class: extra = "" } = Astro.props;

const dimensions = {
  sm: { container: "max-w-[180px]", text: "text-3xl" },
  md: { container: "max-w-xs", text: "text-5xl" },
  lg: { container: "max-w-md", text: "text-7xl" },
};
const d = dimensions[size];
---

<div class:list={["relative w-full mx-auto", d.container, extra]}>
  <div class="absolute -inset-3 rounded-full bg-sage-200/40 blur-2xl"></div>
  {provider.image ? (
    <img
      src={provider.image}
      alt={provider.name}
      class="relative w-full aspect-square rounded-full object-cover ring-1 ring-sage-200 shadow-lg"
      width="1000"
      height="1000"
    />
  ) : (
    <div
      class:list={[
        "relative w-full aspect-square rounded-full bg-sage-100 ring-1 ring-sage-200 shadow-lg flex items-center justify-center",
        d.text,
      ]}
      aria-label={provider.name}
    >
      <span class="font-display text-sage-700 font-medium">{provider.initials}</span>
    </div>
  )}
</div>
